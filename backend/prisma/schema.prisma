// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  PREVENTIVE
  BREAKDOWN
  SERVICE
  INSPECTION
}

enum ExpenseType {
  TOLL
  PARKING
  FOOD
  REPAIR
  FINE
  OTHER
}

enum VehicleType {
  TRUCK
  VAN
  PICKUP
  CONTAINER
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  module      String
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id        String     @id @default(uuid()) @db.Uuid
  firstName String
  lastName  String
  email     String     @unique
  password  String
  phone     String?
  status    UserStatus @default(ACTIVE)
  roleId    String     @db.Uuid
  lastLogin DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  auditLogs AuditLog[]

  @@map("users")
}

model Vehicle {
  id                 String        @id @default(uuid()) @db.Uuid
  registrationNumber String        @unique
  vehicleName        String
  vehicleType        VehicleType
  capacity           Decimal       @db.Decimal(10, 2)
  currentOdometer    Decimal       @db.Decimal(10, 2)
  purchaseCost       Decimal?      @db.Decimal(12, 2)
  manufactureYear    Int
  region             String
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips           Trip[]
  documents       VehicleDocument[]
  maintenances    VehicleMaintenance[]
  fuelLogs        VehicleFuelLog[]
  expenses        Expense[]

  @@map("vehicles")
}

model VehicleDocument {
  id           String    @id @default(uuid()) @db.Uuid
  vehicleId    String    @db.Uuid
  documentType String
  number       String
  expiryDate   DateTime? @db.Date
  fileUrl      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_documents")
}

model Driver {
  id                String       @id @default(uuid()) @db.Uuid
  employeeCode      String       @unique
  firstName         String
  lastName          String
  phone             String
  email             String       @unique
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime?    @db.Date
  safetyScore       Int          @default(100)
  address           String?
  joiningDate       DateTime?    @db.Date
  status            DriverStatus @default(AVAILABLE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  trips      Trip[]
  documents  DriverDocument[]

  @@map("drivers")
}

model DriverDocument {
  id              String    @id @default(uuid()) @db.Uuid
  driverId        String    @db.Uuid
  type            String
  documentNumber  String
  expiryDate      DateTime? @db.Date
  fileUrl         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("driver_documents")
}

model Trip {
  id            String     @id @default(uuid()) @db.Uuid
  tripNumber    String     @unique
  vehicleId     String     @db.Uuid
  driverId      String     @db.Uuid
  source        String
  destination   String
  cargo         String?
  cargoWeight   Decimal?   @db.Decimal(10, 2)
  distance      Decimal?   @db.Decimal(10, 2)
  plannedStart  DateTime?
  plannedEnd    DateTime?
  actualStart   DateTime?
  actualEnd     DateTime?
  startOdometer Decimal?   @db.Decimal(10, 2)
  finalOdometer Decimal?   @db.Decimal(10, 2)
  fuelConsumed  Decimal?   @db.Decimal(10, 2)
  remarks       String?
  status        TripStatus @default(DRAFT)
  createdBy     String     @db.Uuid
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Restrict)

  fuelLogs VehicleFuelLog[]
  expenses Expense[]

  @@map("trips")
}

model VehicleMaintenance {
  id               String             @id @default(uuid()) @db.Uuid
  vehicleId        String             @db.Uuid
  maintenanceType  MaintenanceType
  title            String
  description      String?
  vendor           String?
  cost             Decimal            @db.Decimal(12, 2)
  startedAt        DateTime?
  completedAt      DateTime?
  status           MaintenanceStatus  @default(OPEN)
  createdBy        String             @db.Uuid
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_maintenances")
}

model VehicleFuelLog {
  id            String    @id @default(uuid()) @db.Uuid
  vehicleId     String    @db.Uuid
  tripId        String?   @db.Uuid
  fuelDate      DateTime  @db.Date
  liters        Decimal   @db.Decimal(10, 2)
  pricePerLiter Decimal   @db.Decimal(10, 2)
  totalCost     Decimal   @db.Decimal(12, 2)
  odometer      Decimal?  @db.Decimal(10, 2)
  station       String?
  invoiceNumber String?
  remarks       String?
  createdBy     String    @db.Uuid
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip    Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@map("vehicle_fuel_logs")
}

model Expense {
  id           String      @id @default(uuid()) @db.Uuid
  tripId       String?     @db.Uuid
  vehicleId    String      @db.Uuid
  expenseType  ExpenseType
  amount       Decimal     @db.Decimal(12, 2)
  expenseDate  DateTime    @db.Date
  description  String?
  billNumber   String?
  createdBy    String      @db.Uuid
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  trip    Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  vehicle Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  module    String
  action    String
  recordId  String?  @db.Uuid
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
